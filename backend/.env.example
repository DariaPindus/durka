# Copy this file to .env and fill in real values. .env is gitignored.

POSTGRES_USER=durka
POSTGRES_PASSWORD=changeme
POSTGRES_DB=durka

# From https://my.telegram.org -> API development tools
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Capability token for the /api/messages/* feed API. Generate with: openssl rand -hex 32
# Read-only scope, meant to be rotated periodically (e.g. monthly) once this is exposed
# beyond localhost.
FEED_API_TOKEN=
