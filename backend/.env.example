# Copy this file to .env and fill in real values. .env is gitignored.

POSTGRES_USER=durka
POSTGRES_PASSWORD=changeme
POSTGRES_DB=durka

# From https://my.telegram.org -> API development tools
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# NOTE: there is no database-encryption-key setting here. tdlight-java's TDLibSettings
# does not expose one (verified against its source) - the TDLib session directory is
# unencrypted at rest, protected only by the named Docker volume + host-level disk
# encryption (a broader, separately-tracked requirement).
