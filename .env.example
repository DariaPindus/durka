# Copy to .env (same directory as docker-compose.prod.yml) and fill in real values.
# .env is gitignored. Generate secrets fresh for this server - don't copy them from a
# laptop's dev .env files.

POSTGRES_USER=durka
POSTGRES_PASSWORD=
POSTGRES_DB=durka

# From https://my.telegram.org -> API development tools. Safe to reuse the same value
# from local dev - this identifies the registered app, not a machine/session.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Capability token for the backend's /api/messages/* API. Must be identical to whatever
# the frontend sends - there's only one value, shared between the two services here.
FEED_API_TOKEN=

# The domain Caddy requests a TLS certificate for and reverse-proxies to the frontend.
# Must already have a DNS A (and AAAA, if applicable) record pointing at this server's
# public IP before starting Caddy, or the Let's Encrypt HTTP challenge will fail.
DOMAIN=
