# Copy this file to .env and fill in real values. .env is gitignored.

PORT=3000

# Where the Kotlin/Spring backend is reachable from this process. In local dev this
# process runs inside its own Docker Compose project, separate from the backend's - so
# "localhost" here means this container, not the host or the backend container. Use
# Docker Desktop's host.docker.internal to reach the backend's host-published port
# instead. (Production is different: durka-prod puts both services on one Compose
# network, so docker-compose.prod.yml uses http://backend:8080 there.)
BACKEND_URL=http://host.docker.internal:8080

# Same capability token as backend/.env's FEED_API_TOKEN. This process holds it
# server-side and attaches it to backend calls - it must never be sent to the browser,
# in either the legacy or modern render path.
FEED_API_TOKEN=
