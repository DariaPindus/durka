<!DOCTYPE html>
<html>
<head>
<title>Feed</title>
<style>
body { font-family: sans-serif; font-size: 14px; max-width: 700px; margin: 0 auto; padding: 12px; }
a { color: #06c; text-decoration: none; }
a:hover { text-decoration: underline; }
.note { color: #900; font-size: 12px; }
.error { color: #900; }
label { display: block; margin-top: 8px; }
input[type=text] { width: 100%; box-sizing: border-box; }
textarea { width: 100%; height: 120px; box-sizing: border-box; }
</style>
</head>
<body>
<p class="note">Debug view - temporarily rendering full content for the modern client path (real React UI comes later).</p>
<p><a href="/notes?token=<%= encodeURIComponent(token) %>">&larr; notes</a></p>
<h2>New note</h2>
<% if (error) { %><p class="error"><%= error %></p><% } %>
<form method="POST" action="/notes/new?token=<%= encodeURIComponent(token) %>">
  <label>Title<br><input type="text" name="title" value="<%= title %>"></label>
  <label>Content<br><textarea name="content"><%= content %></textarea></label>
  <p><input type="submit" value="Save"></p>
</form>
</body>
</html>
