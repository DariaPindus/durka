<!DOCTYPE html>
<html>
<head>
<title>Feed</title>
<style>
body { font-family: sans-serif; font-size: 14px; max-width: 700px; margin: 0 auto; padding: 12px; }
a { color: #06c; text-decoration: none; }
a:hover { text-decoration: underline; }
.note { color: #900; font-size: 12px; }
.error { color: #900; }
.hint { color: #666; font-size: 12px; }
label { display: block; margin-top: 8px; }
input[type=text], select { width: 100%; box-sizing: border-box; }
</style>
</head>
<body>
<p class="note">Debug view - temporarily rendering full content for the modern client path (real React UI comes later).</p>
<p><a href="/events?token=<%= encodeURIComponent(token) %>">&larr; events</a></p>
<h2>New task/event</h2>
<% if (error) { %><p class="error"><%= error %></p><% } %>
<form method="POST" action="/events/new?token=<%= encodeURIComponent(token) %>">
  <label>Type<br>
    <select name="type">
      <option value="TASK" <%= type === "TASK" ? "selected" : "" %>>Task</option>
      <option value="EVENT" <%= type === "EVENT" ? "selected" : "" %>>Event</option>
    </select>
  </label>
  <label>Description<br><input type="text" name="description" value="<%= description %>"></label>
  <label>Date (YYYY-MM-DD)<br><input type="text" name="date" value="<%= date %>" placeholder="2026-07-21"></label>
  <label>Time (HH:MM, 24-hour)<br><input type="text" name="time" value="<%= time %>" placeholder="09:00"></label>
  <label>Duration in minutes<br>
    <input type="text" name="durationMinutes" value="<%= durationMinutes %>">
    <br><span class="hint">Only used for Events - leave blank for Tasks.</span>
  </label>
  <p><input type="submit" value="Save"></p>
</form>
</body>
</html>
