<!DOCTYPE html>
<html>
<head>
<title>Feed</title>
<style>
body { font-family: sans-serif; font-size: 14px; }
h2 { font-size: 15px; margin: 10px 0 2px; }
a { color: #009; }
.meta { color: #666; font-size: 12px; }
</style>
</head>
<body>
<p><a href="/?token=<%= encodeURIComponent(token) %>">&lt; sources</a></p>
<% feeds.forEach(function(feed) { %>
  <h2><a href="/rss/feed?url=<%= encodeURIComponent(feed.feedUrl) %>&token=<%= encodeURIComponent(token) %>"><%= feed.feedTitle || feed.feedUrl %></a></h2>
  <p class="meta"><%= feed.itemCount %> items &middot; last <%= feed.lastPublishedAt %></p>
<% }); %>
</body>
</html>
