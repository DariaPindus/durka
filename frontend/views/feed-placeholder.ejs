<!DOCTYPE html>
<html>
<head>
<title>Feed</title>
<style>
body { font-family: sans-serif; font-size: 14px; max-width: 700px; margin: 0 auto; padding: 12px; }
h2 { font-size: 18px; margin: 20px 0 6px; border-bottom: 1px solid #ccc; }
h3 { font-size: 15px; margin: 10px 0 2px; }
p { margin: 2px 0 8px; white-space: pre-wrap; }
.ts { color: #666; font-size: 12px; }
.note { color: #900; font-size: 12px; }
</style>
</head>
<body>
<p class="note">Debug view - temporarily rendering full content for the modern client path (no transliteration, real React UI comes later).</p>
<% groups.forEach(function(group) { %>
  <h2><%= group.chatType %></h2>
  <% group.authors.forEach(function(author) { %>
    <h3><%= author.displayName || author.username || "Unknown" %></h3>
    <% author.messages.forEach(function(message) { %>
      <p><span class="ts"><%= message.timestamp %></span><br><%= message.text %></p>
    <% }); %>
  <% }); %>
<% }); %>
</body>
</html>
