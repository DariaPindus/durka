<!DOCTYPE html>
<html>
<head>
<title>Feed</title>
<style>
body { font-family: sans-serif; font-size: 14px; }
h2 { font-size: 15px; margin: 10px 0 2px; }
a { color: #009; }
.ts { color: #666; font-size: 12px; }
</style>
</head>
<body>
<p><a href="/rss?token=<%= encodeURIComponent(token) %>">&lt; feeds</a></p>
<% entries.forEach(function(entry) { %>
  <h2><a href="/rss/entry/<%= entry.id %>?token=<%= encodeURIComponent(token) %>"><%= entry.title || "(untitled)" %></a></h2>
  <p class="ts"><%= entry.publishedAt %></p>
<% }); %>
</body>
</html>
