<!DOCTYPE html>
<html>
<head>
<title>Feed</title>
<style>
body { font-family: sans-serif; font-size: 14px; }
a { color: #009; }
.ts { color: #666; font-size: 12px; }
.content { white-space: pre-wrap; margin-top: 10px; }
</style>
</head>
<body>
<p><a href="/rss/feed?url=<%= encodeURIComponent(entry.feedUrl) %>&token=<%= encodeURIComponent(token) %>">&lt; <%= entry.feedTitle || entry.feedUrl %></a></p>
<h2><%= entry.title || "(untitled)" %></h2>
<p class="ts"><%= entry.publishedAt %></p>
<div class="content"><%= entry.description || "(no content)" %></div>
<% if (entry.link) { %><p><a href="<%= entry.link %>">Original link</a></p><% } %>
</body>
</html>
