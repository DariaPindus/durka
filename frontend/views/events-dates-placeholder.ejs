<!DOCTYPE html>
<html>
<head>
<title>Feed</title>
<style>
body { font-family: sans-serif; font-size: 14px; max-width: 700px; margin: 0 auto; padding: 12px; }
h2 { font-size: 16px; margin: 14px 0 2px; }
a { color: #06c; text-decoration: none; }
a:hover { text-decoration: underline; }
.count { color: #666; font-size: 12px; }
.note { color: #900; font-size: 12px; }
</style>
</head>
<body>
<p class="note">Debug view - temporarily rendering full content for the modern client path (real React UI comes later).</p>
<p><a href="/?token=<%= encodeURIComponent(token) %>">&larr; sources</a></p>
<p><a href="/events/new?token=<%= encodeURIComponent(token) %>">Add +</a></p>
<% dates.forEach(function(d) { %>
  <h2><a href="/events/<%= d.date %>?token=<%= encodeURIComponent(token) %>"><%= d.date %></a> <span class="count"><%= d.count %> entries</span></h2>
<% }); %>
</body>
</html>
