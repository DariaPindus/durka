<!DOCTYPE html>
<html>
<head>
<title>Feed</title>
<style>
body { font-family: sans-serif; font-size: 14px; }
h2 { font-size: 15px; margin: 12px 0 4px; }
h3 { font-size: 14px; margin: 8px 0 2px; }
p { margin: 2px 0 6px; }
.ts { color: #666; }
</style>
</head>
<body>
<% groups.forEach(function(group) { %>
  <h2><%= group.chatType %></h2>
  <% group.authors.forEach(function(author) { %>
    <h3><%= author.displayName || author.username || "Unknown" %></h3>
    <% author.messages.forEach(function(message) { %>
      <p><span class="ts"><%= message.timestamp %></span><br><%= message.text %></p>
    <% }); %>
  <% }); %>
<% }); %>
</body>
</html>
