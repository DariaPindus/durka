<!DOCTYPE html>
<html>
<head>
<title>Feed</title>
<style>
body { font-family: sans-serif; font-size: 14px; }
h2 { font-size: 15px; margin: 10px 0 2px; }
a { color: #009; }
.ts { color: #666; font-size: 12px; }
.content { white-space: pre-wrap; margin: 2px 0 8px; }
</style>
</head>
<body>
<p><a href="/?token=<%= encodeURIComponent(token) %>">&lt; sources</a></p>
<p><a href="/notes/new?token=<%= encodeURIComponent(token) %>">Add +</a></p>
<% notes.forEach(function(note) { %>
  <h2><%= note.title %></h2>
  <p class="ts">last edited <%= note.updatedAt %></p>
  <p class="content"><%= note.content %></p>
<% }); %>
</body>
</html>
