<!DOCTYPE html>
<html>
<head>
<title>Feed</title>
<style>
body { font-family: sans-serif; font-size: 14px; }
h2 { font-size: 15px; margin: 10px 0 2px; }
a { color: #009; }
.ts { color: #666; font-size: 12px; }
</style>
</head>
<body>
<% senders.forEach(function(sender) { %>
  <h2><a href="/feed/<%= sender.chatId %>?token=<%= encodeURIComponent(token) %>"><%= sender.displayName || sender.username || "Unknown" %></a></h2>
  <p class="ts"><%= sender.lastMessageAt %></p>
<% }); %>
</body>
</html>
